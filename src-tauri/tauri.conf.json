{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Operation HQ",
  "version": "0.1.0",
  "identifier": "com.keeply.hq",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://hq.svirene.com"
  },
  "app": {
    "windows": [
      {
        "title": "Operation HQ",
        "url": "https://hq.svirene.com",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  }
}
