{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-access",
  "description": "Allows hq.svirene.com to invoke custom commands",
  "windows": ["main"],
  "remote": {
    "urls": ["https://hq.svirene.com/*"]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    "shell:allow-open"
  ]
}
